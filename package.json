{
  "name": "pi-bg-process-windows",
  "version": "2.0.0",
  "description": "Auto-backgrounding for PI on Windows — shadows built-in bash, detaches long commands, auto-notifies on completion",
  "keywords": [
    "pi-package",
    "background",
    "bash",
    "windows",
    "auto-background"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target node",
    "dev": "bun run --watch src/test.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": ">=0.60.0",
    "@mariozechner/pi-tui": "*"
  },
  "devDependencies": {
    "@marcfargas/pi-test-harness": "^0.5.0",
    "@types/node": "^20.0.0",
    "vitest": "^4.1.4"
  }
}
